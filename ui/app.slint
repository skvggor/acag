import {
    LineEdit, ComboBox, Button, CheckBox, Slider, Spinner,
    VerticalBox, HorizontalBox, ScrollView,
} from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "article cover art generator";
    preferred-width: 1180px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 720px;
    background: #15130f;

    // Set from Rust.
    in property <image> preview;
    in property <string> status;
    in property <bool> exporting;
    in property <[string]> themes;
    in property <[string]> patterns;
    in property <[string]> layouts;
    in property <[string]> sizes;

    // Editable state.
    in-out property <string> title-text;
    in-out property <string> category-text;
    in-out property <string> date-text;
    in-out property <string> number-text;
    in-out property <string> brand-text;
    in-out property <int> theme-index;
    in-out property <int> pattern-index;
    in-out property <int> layout-index;
    in-out property <int> size-index;
    in-out property <float> grain-value;
    in-out property <float> pattern-value;
    in-out property <bool> open-after;

    callback changed();
    callback export-png();
    callback export-svg();
    callback omakase();
    callback save-preset();
    callback load-preset();

    HorizontalBox {
        padding: 22px;
        spacing: 22px;

        // ---- Controls ----
        Rectangle {
            width: 360px;
            background: #1c1a17;
            border-radius: 10px;

            ScrollView {
                VerticalBox {
                    width: 360px;
                    padding: 24px;
                    spacing: 9px;
                    alignment: start;

                    Text {
                        text: "ARTICLE COVER ART";
                        color: #d89868;
                        font-size: 13px;
                        font-weight: 800;
                        letter-spacing: 2px;
                    }
                    Text {
                        text: "Omakase · square 1:1";
                        color: #8a7e6a;
                        font-size: 12px;
                    }

                    Text { text: "Title"; color: #d4c4a8; font-size: 11px; }
                    LineEdit {
                        text <=> root.title-text;
                        placeholder-text: "Article title";
                        edited => { root.changed(); }
                    }

                    Text { text: "Category"; color: #d4c4a8; font-size: 11px; }
                    LineEdit {
                        text <=> root.category-text;
                        placeholder-text: "optional";
                        edited => { root.changed(); }
                    }

                    Text { text: "Date"; color: #d4c4a8; font-size: 11px; }
                    LineEdit {
                        text <=> root.date-text;
                        placeholder-text: "optional";
                        edited => { root.changed(); }
                    }

                    Text { text: "Number"; color: #d4c4a8; font-size: 11px; }
                    LineEdit {
                        text <=> root.number-text;
                        placeholder-text: "optional";
                        edited => { root.changed(); }
                    }

                    Text { text: "Brand"; color: #d4c4a8; font-size: 11px; }
                    LineEdit {
                        text <=> root.brand-text;
                        placeholder-text: "optional";
                        edited => { root.changed(); }
                    }

                    Text { text: "Theme"; color: #d4c4a8; font-size: 11px; }
                    ComboBox {
                        model: root.themes;
                        current-index <=> root.theme-index;
                        selected => { root.changed(); }
                    }

                    Text { text: "Pattern"; color: #d4c4a8; font-size: 11px; }
                    ComboBox {
                        model: root.patterns;
                        current-index <=> root.pattern-index;
                        selected => { root.changed(); }
                    }

                    Text { text: "Layout"; color: #d4c4a8; font-size: 11px; }
                    ComboBox {
                        model: root.layouts;
                        current-index <=> root.layout-index;
                        selected => { root.changed(); }
                    }

                    Text { text: "Pattern strength"; color: #d4c4a8; font-size: 11px; }
                    Slider {
                        minimum: 0;
                        maximum: 1.0;
                        value <=> root.pattern-value;
                        changed(v) => { root.changed(); }
                    }

                    Text { text: "Film grain"; color: #d4c4a8; font-size: 11px; }
                    Slider {
                        minimum: 0;
                        maximum: 1.0;
                        value <=> root.grain-value;
                        changed(v) => { root.changed(); }
                    }

                    Text { text: "Export size"; color: #d4c4a8; font-size: 11px; }
                    ComboBox {
                        model: root.sizes;
                        current-index <=> root.size-index;
                    }
                    CheckBox {
                        text: "Open after export";
                        checked <=> root.open-after;
                    }

                    HorizontalBox {
                        padding: 0;
                        padding-top: 6px;
                        spacing: 10px;
                        Button {
                            text: "Omakase";
                            clicked => { root.omakase(); }
                        }
                        Button {
                            text: "Export PNG";
                            primary: true;
                            enabled: !root.exporting;
                            clicked => { root.export-png(); }
                        }
                    }
                    HorizontalBox {
                        padding: 0;
                        spacing: 10px;
                        Button {
                            text: "Export SVG";
                            enabled: !root.exporting;
                            clicked => { root.export-svg(); }
                        }
                    }
                    HorizontalBox {
                        padding: 0;
                        spacing: 10px;
                        Button {
                            text: "Save preset";
                            clicked => { root.save-preset(); }
                        }
                        Button {
                            text: "Load preset";
                            clicked => { root.load-preset(); }
                        }
                    }

                    HorizontalBox {
                        padding: 0;
                        padding-top: 4px;
                        spacing: 8px;
                        if root.exporting: Spinner {
                            indeterminate: true;
                            width: 18px;
                            height: 18px;
                        }
                        Text {
                            text: root.exporting ? "Saving…" : root.status;
                            color: #8a7e6a;
                            font-size: 11px;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ---- Preview ----
        Rectangle {
            background: #1c1a17;
            border-radius: 10px;

            Image {
                source: root.preview;
                image-fit: contain;
                x: 24px;
                y: 24px;
                width: parent.width - 48px;
                height: parent.height - 48px;
            }
        }
    }
}
